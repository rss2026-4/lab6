<launch>
    <node pkg="path_planning" exec="map_inflator" name="map_inflator" output="screen"/>
    <node pkg="path_planning" exec="rrt_planner" name="rrt_planner" output="screen">
        <param from="$(find-pkg-share path_planning)/config/sim/sim_config.yaml"/>
    </node>
    <node pkg="path_planning" exec="astar_planner" name="astar_planner" output="screen">
        <param from="$(find-pkg-share path_planning)/config/sim/sim_config.yaml"/>
    </node>
    <node pkg="path_planning" exec="trajectory_follower" name="trajectory_follower">
        <param from="$(find-pkg-share path_planning)/config/sim/sim_config.yaml"/>
    </node>
</launch>