<launch>
    <!-- Particle filter -->
    <include file="$(find-pkg-share localization)/launch/localize.launch.xml"/>

    <!-- Safety controller -->
    <node pkg="safety_controller" exec="safety_controller" name="safety_controller" output="screen"/>

    <!-- Trajectory planner -->
    <node pkg="path_planning" exec="rrt_planner" name="rrt_planner" output="screen">
        <param from="$(find-pkg-share path_planning)/config/sim/sim_config.yaml"/>
    </node>

    <!-- Trajectory follower -->
    <node pkg="path_planning" exec="trajectory_follower" name="trajectory_follower" output="screen">
        <param from="$(find-pkg-share path_planning)/config/sim/sim_config.yaml"/>
    </node>
</launch>
